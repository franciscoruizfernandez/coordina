# ============================================
# COORDINA BACKEND - Variables d'entorn
# ============================================

# Port del servidor
PORT=3000

# Base de dades PostgreSQL (Supabase)
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# JWT Secret per autenticació (genera'n un amb: openssl rand -base64 32)
JWT_SECRET=el_teu_secret_super_segur_aqui

# Supabase
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=la_teva_anon_key_aqui

# Entorn (development, production)
NODE_ENV=development

# CORS - Dominis permesos (separats per comes)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100